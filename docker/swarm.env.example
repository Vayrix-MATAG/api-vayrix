# Déploiement Docker Swarm UNIQUEMENT — non utilisé en développement local.
# En local, configurez .env à la racine du projet.
# Usage : export $(grep -v '^#' docker/swarm.env | xargs) && docker stack deploy -c docker-stack.yml vayrix

FRONTEND_URL=https://app.vayrix.com
CORS_ORIGINS=https://app.vayrix.com

# SMTP
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=VAYRIX
MAIL_LOGO_URL=

# SMS (production)
SMS_PROVIDER=http
SMS_API_URL=https://api.votre-fournisseur-sms.com/v1/send
SMS_SENDER_ID=VAYRIX

# JWT
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OTP
OTP_EXPIRY_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
