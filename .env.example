# =============================================================================
# MODÈLE GIT UNIQUEMENT — ne pas utiliser ce fichier pour l'exécution.
# Copiez son contenu dans .env et configurez vos valeurs réelles.
# =============================================================================

# --- Application ---
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:3000

# --- Base de données PostgreSQL ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vayrix_api?schema=public"
DATABASE_POOL_MAX=10

# --- JWT ---
JWT_SECRET=change-me-super-secret-jwt-key-vayrix-2026
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-super-secret-refresh-key-vayrix-2026
JWT_REFRESH_EXPIRES_IN=7d

# --- SMTP (Nodemailer) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=VAYRIX
MAIL_LOGO_URL=

# --- OTP ---
OTP_EXPIRY_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# --- SMS ---
SMS_PROVIDER=mock
SMS_API_URL=
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=VAYRIX

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:4200

# --- Rate limiting ---
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# --- Upload ---
STORAGE_PATH=storage
MAX_FILE_SIZE=10485760

# --- Tarification ---
CURRENCY=XOF
BASE_FARE=500
PER_KM_RATE=250
PER_MIN_RATE=50
